{
  "name": "claude-os",
  "version": "0.5.5",
  "description": "An AI-powered operating system for startups. One slash command instantiates your entire company as parallel steering agents that watch, decide, and coordinate through shared state.",
  "keywords": [
    "ai-agents",
    "claude",
    "company-os",
    "autonomous",
    "mcp",
    "claude-code",
    "claude",
    "memory",
    "multi-agent",
    "parallel-agents"
  ],
  "author": "Jordan Plows <jordan@plows.ai>",
  "license": "MIT",
  "homepage": "https://github.com/jordantplows/startup-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordantplows/startup-os.git"
  },
  "bugs": {
    "url": "https://github.com/jordantplows/startup-os/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "startup-os": "./dist/cli.js"
  },
  "files": [
    "dist",
    ".claude",
    ".claude-plugin",
    "CLAUDE.md",
    "README.md",
    "ceo",
    "cfo",
    "cmo",
    "cto",
    "cpo",
    "coo",
    "strategy",
    "finance",
    "legal",
    "design",
    "engineering",
    "marketing",
    "sales",
    "people",
    "operations",
    "metrics",
    "growth",
    "customer",
    "data",
    "debug",
    "core",
    "templates",
    "outreach",
    "investor",
    "research",
    "network"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/install.js",
    "start": "node dist/cli.js",
    "version:patch": "npm version patch && npm publish --access public",
    "version:minor": "npm version minor && npm publish --access public",
    "version:major": "npm version major && npm publish --access public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@supabase/supabase-js": "^2.39.0",
    "cron": "^3.1.7",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/cron": "^2.0.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
