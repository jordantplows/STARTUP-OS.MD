{
  "name": "@jordan.plows/startup-os",
  "version": "0.1.0",
  "description": "A complete AI-powered operating system for startups — from idea to funded company with a single command.",
  "keywords": [
    "startup",
    "ai",
    "agents",
    "claude",
    "business",
    "founder",
    "operating-system"
  ],
  "author": "Jordan Plows <jordan@plows.ai>",
  "license": "MIT",
  "homepage": "https://github.com/jordantplows/startup-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordantplows/startup-os.git"
  },
  "bugs": {
    "url": "https://github.com/jordantplows/startup-os/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "startup-os": "./dist/cli.js"
  },
  "files": [
    "dist",
    "strategy",
    "brand",
    "product",
    "finance",
    "marketing",
    "sales",
    "legal",
    "people",
    "operations",
    "metrics",
    "security",
    "engineering",
    ".claude",
    ".claude-plugin",
    "CLAUDE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "version:patch": "npm version patch && npm publish --access public",
    "version:minor": "npm version minor && npm publish --access public",
    "version:major": "npm version major && npm publish --access public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
